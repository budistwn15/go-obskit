# =========================
# go-obskit .env example (minimal: 5 keys)
# =========================
# Optional advanced keys: see .env.full.example

APP_NAME=my-service
APP_ENV=production
LOG_LEVEL=info
OBSKIT_ELASTIC_ENABLED=false
OBSKIT_ELASTIC_URL=http://localhost:9200
OBSKIT_ELASTIC_INDEX=xeanees-logs
OBSKIT_ELASTIC_USERNAME=
OBSKIT_ELASTIC_PASSWORD=
