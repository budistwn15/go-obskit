# =========================
# go-obskit .env example
# =========================
# NOTE:
# - obskit does not auto-read .env by itself.
# - Your app should load these vars (godotenv / env loader) and map them to obskit config.

# -------------------------
# Core logger
# -------------------------
APP_NAME=my-service
APP_VERSION=1.0.0
APP_ENV=production
LOG_LEVEL=info
LOG_FORMAT=json
LOG_ADD_SOURCE=false
LOG_INSTANCE_ID=
OBSKIT_SINK_PROVIDER=stdout

# -------------------------
# Incoming HTTP logging (net/http, gin, fiber)
# -------------------------
OBSKIT_HTTP_FORENSIC=false
OBSKIT_HTTP_CAPTURE_HEADERS=false
OBSKIT_HTTP_CAPTURE_QUERY=true
OBSKIT_HTTP_CAPTURE_REQUEST_BODY=false
OBSKIT_HTTP_CAPTURE_RESPONSE_BODY=false
OBSKIT_HTTP_LOG_SUCCESS_BODIES=false
OBSKIT_HTTP_LOG_ERROR_BODIES=true
OBSKIT_HTTP_MAX_BODY_BYTES=16384
OBSKIT_HTTP_SLOW_THRESHOLD_MS=1000
OBSKIT_HTTP_SUCCESS_SAMPLE_EVERY=1

# -------------------------
# Outbound HTTP logging
# -------------------------
OBSKIT_OUTBOUND_FORENSIC=false
OBSKIT_OUTBOUND_CAPTURE_HEADERS=false
OBSKIT_OUTBOUND_CAPTURE_QUERY=true
OBSKIT_OUTBOUND_CAPTURE_REQUEST_BODY=false
OBSKIT_OUTBOUND_CAPTURE_RESPONSE_BODY=false
OBSKIT_OUTBOUND_MAX_BODY_BYTES=16384
OBSKIT_OUTBOUND_SLOW_THRESHOLD_MS=1000
OBSKIT_OUTBOUND_SUCCESS_SAMPLE_EVERY=1

# -------------------------
# GORM logging
# -------------------------
OBSKIT_GORM_TRACING=true
OBSKIT_GORM_LOG_SUCCESS=true
OBSKIT_GORM_LOG_SQL=true
OBSKIT_GORM_LOG_SQL_ON_ERROR=true
OBSKIT_GORM_LOG_SQL_ON_SLOW=true
OBSKIT_GORM_LOG_SQL_ON_SUCCESS=true
OBSKIT_GORM_MAX_SQL_LEN=4096
OBSKIT_GORM_SLOW_THRESHOLD_MS=250
OBSKIT_GORM_SUCCESS_SAMPLE_EVERY=1
OBSKIT_GORM_IGNORE_RECORD_NOT_FOUND=true

# -------------------------
# Elasticsearch / OpenSearch sink (optional)
# -------------------------
OBSKIT_ELASTIC_ENABLED=true
OBSKIT_ELASTIC_URL=http://localhost:9200
OBSKIT_ELASTIC_INDEX=obskit-logs
OBSKIT_ELASTIC_USERNAME=elastic
OBSKIT_ELASTIC_PASSWORD=secret
OBSKIT_ELASTIC_API_KEY=

# index naming
OBSKIT_ELASTIC_INDEX_TIMESTAMP_SUFFIX=true
OBSKIT_ELASTIC_INDEX_TIMESTAMP_LAYOUT=2006.01.02
OBSKIT_ELASTIC_INDEX_PATTERN=obskit-logs-*

# performance / retry
OBSKIT_ELASTIC_TIMEOUT_MS=2000
OBSKIT_ELASTIC_QUEUE_SIZE=2048
OBSKIT_ELASTIC_BATCH_SIZE=200
OBSKIT_ELASTIC_FLUSH_INTERVAL_MS=1000
OBSKIT_ELASTIC_BLOCK_ON_QUEUE_FULL=false
OBSKIT_ELASTIC_MAX_RETRIES=3
OBSKIT_ELASTIC_RETRY_BACKOFF_MS=150
OBSKIT_ELASTIC_MAX_BACKOFF_MS=2000

# monitoring / bootstrap
OBSKIT_ELASTIC_ENABLE_MONITOR=true
OBSKIT_ELASTIC_MONITOR_INTERVAL_MS=15000
OBSKIT_ELASTIC_MONITOR_PATH=/
OBSKIT_ELASTIC_BOOTSTRAP=true
OBSKIT_ELASTIC_BOOTSTRAP_ON_START=true
OBSKIT_ELASTIC_PIPELINE_NAME=obskit-default-pipeline
OBSKIT_ELASTIC_TEMPLATE_NAME=obskit-default-template
OBSKIT_ELASTIC_APPLY_PIPELINE_TO_EXISTING=true

# stdout status logs for sink
OBSKIT_ELASTIC_CONNECTION_LOG_TO_STDOUT=true
OBSKIT_ELASTIC_CONNECTION_LOG_ALL_CHECKS=false

# -------------------------
# Generic HTTP sink (optional, vendor-agnostic)
# -------------------------
OBSKIT_HTTP_SINK_ENABLED=false
OBSKIT_HTTP_SINK_URL=http://localhost:8088/logs
OBSKIT_HTTP_SINK_FORMAT=ndjson
OBSKIT_HTTP_SINK_HEADERS=X-Api-Key:token
OBSKIT_HTTP_SINK_API_KEY=
OBSKIT_HTTP_SINK_USERNAME=
OBSKIT_HTTP_SINK_PASSWORD=
OBSKIT_HTTP_SINK_TIMEOUT_MS=2000
OBSKIT_HTTP_SINK_QUEUE_SIZE=2048
OBSKIT_HTTP_SINK_BATCH_SIZE=200
OBSKIT_HTTP_SINK_FLUSH_INTERVAL_MS=1000
OBSKIT_HTTP_SINK_BLOCK_ON_QUEUE_FULL=false
OBSKIT_HTTP_SINK_MAX_RETRIES=3
OBSKIT_HTTP_SINK_RETRY_BACKOFF_MS=150
OBSKIT_HTTP_SINK_MAX_BACKOFF_MS=2000
OBSKIT_HTTP_SINK_CONNECTION_LOG_TO_STDOUT=true

# -------------------------
# Grafana Loki sink (optional)
# -------------------------
OBSKIT_LOKI_ENABLED=false
OBSKIT_LOKI_URL=http://localhost:3100
OBSKIT_LOKI_LABELS=source:obskit,env:production
OBSKIT_LOKI_API_KEY=
OBSKIT_LOKI_USERNAME=
OBSKIT_LOKI_PASSWORD=
OBSKIT_LOKI_TIMEOUT_MS=2000
OBSKIT_LOKI_QUEUE_SIZE=2048
OBSKIT_LOKI_BATCH_SIZE=200
OBSKIT_LOKI_FLUSH_INTERVAL_MS=1000
OBSKIT_LOKI_BLOCK_ON_QUEUE_FULL=false
OBSKIT_LOKI_MAX_RETRIES=3
OBSKIT_LOKI_RETRY_BACKOFF_MS=150
OBSKIT_LOKI_MAX_BACKOFF_MS=2000
OBSKIT_LOKI_CONNECTION_LOG_TO_STDOUT=true
